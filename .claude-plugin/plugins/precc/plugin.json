{
  "$schema": "https://anthropic.com/claude-code/plugin.schema.json",
  "name": "precc",
  "version": "1.0.0",
  "description": "Predictive Error Correction for Claude Code — a PreToolUse hook that corrects bash commands before execution. Learns failure-fix patterns from session logs.",
  "author": {
    "name": "Yijun Yu",
    "email": "yijun.yu@open.ac.uk"
  },
  "homepage": "https://github.com/yijunyu/precc-cc",
  "binaries": [
    "precc",
    "precc-hook",
    "precc-miner"
  ],
  "env": [
    {
      "name": "PRECC_LICENSE_KEY",
      "required": false,
      "description": "Optional Pro license key for premium features (savings --all)"
    }
  ],
  "config_paths": [
    "~/.local/share/precc/history.db",
    "~/.local/share/precc/heuristics.db",
    "~/.claude/settings.json"
  ],
  "install": [
    {
      "kind": "script",
      "command": "curl -fsSL https://raw.githubusercontent.com/yijunyu/precc-cc/main/scripts/install.sh | bash",
      "bins": ["precc", "precc-hook", "precc-miner"]
    }
  ],
  "commands": "./commands/"
}
